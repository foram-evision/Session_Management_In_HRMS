{ //Logging means recording what is happening inside your application. 
  //why ? The Login API failed yesterday. Without logs:You have no idea what happened.With logs:You immediately know the issue.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=HR Managements;Username=postgres;Password=Welcome@123"
  },
  "JwtSettings": {
    "SecretKey": "SuperSecretKeyForHrmsPocCleanArchitectureWithAtLeast32BytesLength!",
    "Issuer": "HRMS.API",
    "Audience": "HRMS.Client",
    "ExpiryMinutes": 60,
    "SlidingExpiryDays": 2,
    "AbsoluteExpiryDays": 7
  }
}

//appsettings.json is the configuration file used to store application settings that can change between environments 
//without changing the source code.
